{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TvSorter",
  "version": "0.2.0",
  "identifier": "com.tvsorter.desktop",
  "build": {
    "beforeBuildCommand": "cd ../frontend && npm ci && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Sort TV, anime, and film files into clean libraries.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
